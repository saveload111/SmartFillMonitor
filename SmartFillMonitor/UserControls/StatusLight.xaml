<UserControl x:Class="SmartFillMonitor.UserControls.StatusLight"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartFillMonitor.UserControls"
             xmlns:cv="clr-namespace:SmartFillMonitor.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Width="40" Height="120">
    <UserControl.Resources>
        <cv:LightStateToBrushConverter x:Key="LightStateToBrushConverter"/>

    </UserControl.Resources>
    <Grid Background="Transparent">
        <Border CornerRadius="10" Background="#222" BorderBrush="#111" BorderThickness="2" Width="36" Height="110" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="8" Opacity="0.3"/>
            </Border.Effect>
        </Border>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
           <!--绿灯-->
            <Grid Width="25" Height="25" Margin="0,4">
                <Ellipse>
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#22000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Clip>
                        <EllipseGeometry Center="12.5,12.5" RadiusX="12.5" RadiusY="12.5"/>
                    </Ellipse.Clip>
                </Ellipse>
                <Ellipse x:Name="GreenEllipse" Stroke="#111" StrokeThickness="1.5">
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1" >
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="{Binding State,RelativeSource={RelativeSource AncestorType=UserControl},Converter={StaticResource LightStateToBrushConverter},ConverterParameter=Green}" Offset="0.4"/>
                            <GradientStop Color="#88000000" Offset="1"/>


                        </LinearGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="2" KernelType="Gaussian"/>
                    </Ellipse.Effect>
                  
                </Ellipse>
                <Ellipse Width="8" Height="9" Margin="4,3" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#AAFFFFFF" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </RadialGradientBrush>
                        
                    </Ellipse.Fill>
                    
                </Ellipse>
            </Grid>
           <!--黄灯-->
            <Grid Width="25" Height="25" Margin="0,4">
                <Ellipse>
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#22000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Clip>
                        <EllipseGeometry Center="12.5,12.5" RadiusX="12.5" RadiusY="12.5"/>
                    </Ellipse.Clip>
                </Ellipse>
                <Ellipse x:Name="YellowEllipse" Stroke="#111" StrokeThickness="1.5">
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1" >
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="{Binding State,RelativeSource={RelativeSource AncestorType=UserControl},Converter={StaticResource LightStateToBrushConverter},ConverterParameter=Yellow}" Offset="0.4"/>
                            <GradientStop Color="#88000000" Offset="1"/>


                        </LinearGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="2" KernelType="Gaussian"/>
                    </Ellipse.Effect>

                </Ellipse>
                <Ellipse Width="8" Height="9" Margin="4,3" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#AAFFFFFF" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </RadialGradientBrush>

                    </Ellipse.Fill>

                </Ellipse>
            </Grid>

            <!--红灯-->
            <Grid Width="25" Height="25" Margin="0,4">
                <Ellipse>
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#22000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Clip>
                        <EllipseGeometry Center="12.5,12.5" RadiusX="12.5" RadiusY="12.5"/>
                    </Ellipse.Clip>
                </Ellipse>
                <Ellipse x:Name="RedEllipse" Stroke="#111" StrokeThickness="1.5">
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1" >
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="{Binding State,RelativeSource={RelativeSource AncestorType=UserControl},Converter={StaticResource LightStateToBrushConverter},ConverterParameter=Red}" Offset="0.4"/>
                            <GradientStop Color="#88000000" Offset="1"/>


                        </LinearGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="2" KernelType="Gaussian"/>
                    </Ellipse.Effect>

                </Ellipse>
                <Ellipse Width="8" Height="9" Margin="4,3" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#AAFFFFFF" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </RadialGradientBrush>

                    </Ellipse.Fill>

                </Ellipse>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
